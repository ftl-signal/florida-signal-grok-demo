# Phase 2B — Environment variables for local / Vercel preview
# Copy this file to .env.local (or set in Vercel) for live Supabase access.

# Required for LIVE mode (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# NOTE:
# - These are used ONLY inside server-side API routes (api/permits.js).
# - Never expose SUPABASE_ANON_KEY in browser code.
# - If these are not set, the app stays in full demo mode (synthetic data).
# - This is the intended safe default.
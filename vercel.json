{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "devCommand": "python3 -m http.server 4173 || python -m http.server 4173",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "regions": ["iad1"]
}